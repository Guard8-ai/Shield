  "version": "3.0",
  "description": "Shield v3 cross-language test vectors. Encryption is randomized (random salt + nonce + padding), so vectors are pre-encrypted ciphertexts that every language DECRYPTS to a known plaintext. Generated once with the verified Python implementation (python/shield/core.py).",
  "format": {
    "password_mode": "version(0x02) || salt(16) || nonce(16) || ciphertext || mac(16)",
    "key_mode": "version(0x12) || nonce(16) || ciphertext || mac(16)",
    "mac": "HMAC-SHA256(mac_key, version || [salt] || nonce || ciphertext) truncated to 16 bytes",
    "inner_layout": "counter(8) || timestamp_ms(8) || pad_len(1) || padding(32-128) || plaintext"
  },
  "note_on_freshness": "These ciphertexts carry a fixed timestamp and will age out of the default 60s freshness window. Decrypt them with the freshness window disabled (max_age_ms=None / nil), mirroring python/tests which uses max_age_ms=None for pre-generated ciphertext.",
